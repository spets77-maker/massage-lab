# Copy to .deploy-credentials (same folder) and fill in. Do not commit .deploy-credentials.
#
# GoDaddy: FTP host is often ftp.yourdomain.com — check Hosting → cPanel → FTP Accounts.

YML_DEPLOY_HOST=ftp.yuliasmassagelab.com
YML_DEPLOY_USER=spets
YML_DEPLOY_PASS=

# Path relative to FTP home (often equals public_html/... in File Manager).
# Staging folder is created automatically if missing.
YML_REMOTE_DIR=public_html/yuliasmassagelab.com/staging
